# RadSec (RADIUS over TLS, RFC 6614) virtual server.
# Handles RADIUS authentication forwarded by home routers over a mutual-TLS
# connection on port 2083.  Each router client is registered in the radsec
# clients section below, so FreeRADIUS routes their requests here.

# Named client section associated with the RadSec TLS listener.
# Clients here inherit TLS from the listener; no tls{} block is needed per
# client entry.  The dynamic file is written by PINT and reloaded via SIGHUP.
clients radsec {
    $-INCLUDE /etc/pint/config/clients.conf
}

server radsec {

    listen {
        type    = auth
        ipaddr  = *
        port    = 2083
        proto   = tcp
        clients = radsec

        # TLS block generated by PINT and written to the config secret.
        # check_crl is controlled via PINT_RADIUS_RADSEC_CHECK_CRL (default: true).
        $INCLUDE /etc/pint/config/radsec-tls.conf
    }

    authorize {
        eap
    }

    authenticate {
        Auth-Type EAP {
            eap
        }
    }

    post-auth {
        Post-Auth-Type REJECT {
            attr_filter.access_reject
        }
    }
}
